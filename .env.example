# kie.ai
KIE_API_KEY=
# Optional: override createTask endpoint (POST). Default below — adjust to match kie.ai docs.
# KIE_CREATE_TASK_URL=https://api.kie.ai/api/v1/jobs/createTask

# Public base URL for webhooks (no trailing slash). On Vercel, VERCEL_URL is set automatically.
# NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

# Vercel Blob (from Vercel dashboard → Storage → Blob) — videos + job JSON at jobs/{taskId}.json
PPL_BLOB_READ_WRITE_TOKEN=
